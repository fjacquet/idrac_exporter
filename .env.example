# Copy to .env and fill in — `.env` is gitignored, never commit real secrets.
# Compose reads .env natively; config.yaml references these as ${IDRAC1_*}.

# BMC scraped when /metrics is called without a ?target= parameter.
IDRAC1_HOST=192.168.1.1

# Read-only BMC user for the exporter (a dedicated unprivileged user is recommended).
IDRAC1_USERNAME=root
IDRAC1_PASSWORD=changeme

# Grafana admin password for the local test stack.
GF_SECURITY_ADMIN_PASSWORD=admin
