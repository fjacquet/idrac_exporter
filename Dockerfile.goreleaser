# Release image: copies the GoReleaser-built binary (no builder stage, so it
# cannot copy certs from a builder). Built in CI with open egress, so the
# ca-certificates fetch is tolerated here.
FROM alpine:3.23

WORKDIR /app
RUN apk add --no-cache ca-certificates && adduser -D -u 10001 idrac

COPY idrac_exporter /app/bin/idrac_exporter
COPY default-config.yml /etc/prometheus/idrac.yml
COPY entrypoint.sh /app/entrypoint.sh

RUN chown -R idrac /app
USER idrac

ENTRYPOINT ["/app/entrypoint.sh"]
